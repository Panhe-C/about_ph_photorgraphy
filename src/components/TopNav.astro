---
interface Props {
  currentPage?: 'home' | 'works' | 'about';
}

const { currentPage } = Astro.props;
---

<header class="topnav">
  <div class="container topnav-inner">
    <a class="logo" href="/">P.H.</a>
    <nav aria-label="Primary navigation">
      <a href="/" aria-current={currentPage === 'home' ? 'page' : undefined}>( 01 ) Home</a>
      <a href="/works" aria-current={currentPage === 'works' ? 'page' : undefined}>( 02 ) Works</a>
      <a href="/about" aria-current={currentPage === 'about' ? 'page' : undefined}>( 03 ) About</a>
    </nav>
    <a class="contact-link" href="/about#contact">Get in touch</a>
  </div>
</header>
