---
interface Props {
  pageLabel: string;
  tagline?: string;
}

const { pageLabel, tagline = 'Art photography' } = Astro.props;
---

<footer class="pagefoot">
  <div class="container foot-grid meta">
    <span>&copy; P.H. / 2026</span>
    <span>{pageLabel}</span>
    <span>{tagline}</span>
  </div>
</footer>
