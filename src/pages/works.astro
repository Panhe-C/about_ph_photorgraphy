---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { getWorks } from '../data/works';

const works = getWorks();
---

<BaseLayout
  title="Works"
  description="Photography / selected plates by P.H. — interiors, thresholds, late light."
>
  <!-- Fixed transparent nav -->
  <header class="topnav-fixed" data-od-id="topnav">
    <div class="topnav-fixed-inner">
      <nav aria-label="Primary navigation">
        <a href="/" class="nav-home">HOME</a>
        <a href="/works" class="nav-work" aria-current="page">WORK</a>
      </nav>
    </div>
  </header>

  <main id="content">
    <section class="section hero-section" data-od-id="works-hero">
      <div class="container hero">
        <div>
          <p class="eyebrow">Photography / selected plates</p>
          <h1>Works</h1>
        </div>
        <p class="lead">Select a series to browse. Click thumbnails to view individual plates.</p>
      </div>
    </section>

    <section class="section" data-od-id="plate-viewer">
      <div class="container viewer">
        <!-- Left: series list -->
        <div class="work-list" role="group" aria-label="Select series">
          {works.map((work, i) => (
            <button
              class="work-button meta"
              type="button"
              data-index={String(i)}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              <span>{String(i + 1).padStart(2, '0')}</span>
              <span>{work.title}</span>
            </button>
          ))}
        </div>

        <!-- Center: gallery -->
        <div class="gallery-wrap">
          <div class="viewer-top meta">
            <span id="plateCounter">01 / {String(works[0].photos.length).padStart(2, '0')}</span>
            <span id="plateSeries">{works[0].series}</span>
          </div>

          <!-- Main plate -->
          <div
            class="plate is-photo"
            id="plate"
            aria-live="polite"
            aria-label="Selected photograph"
            style={`background: url(${works[0].photos[0]}) center / cover no-repeat`}
          >
            <span id="plateTitle">{works[0].title}</span>
          </div>

          <div class="viewer-bottom meta">
            <span id="plateCaption">{works[0].caption}</span>
            <span>Selected plate</span>
          </div>

          <!-- Thumbnail strip -->
          <div class="thumb-strip" id="thumbStrip" role="group" aria-label="Series photographs">
            {works[0].photos.map((photo, pi) => (
              <button
                class="thumb"
                type="button"
                data-photo-index={String(pi)}
                aria-pressed={pi === 0 ? 'true' : 'false'}
                style={`background-image: url(${photo})`}
              >
                <span class="sr-only">Photo {pi + 1}</span>
              </button>
            ))}
          </div>
        </div>

        <!-- Right: metadata -->
        <aside class="data-panel" aria-label="Selected work metadata">
          <div class="data-list">
            <div class="data-row meta"><span>Year</span><span id="plateYear">{works[0].year}</span></div>
            <div class="data-row meta"><span>Ratio</span><span id="plateRatio">{works[0].ratio}</span></div>
            <div class="data-row meta"><span>Mode</span><span>Still image</span></div>
            <div class="data-row meta"><span>Print</span><span id="platePrint">{works[0].print}</span></div>
            <div class="data-row meta"><span>Plates</span><span id="plateCount">{String(works[0].photos.length)}</span></div>
          </div>
          <a class="btn" href="/about#contact">Request packet</a>
        </aside>
      </div>
    </section>
  </main>

  <Footer pageLabel="Works" tagline="Six series, multiple plates" />
</BaseLayout>

<script>
  import { getWorks } from '../data/works';

  const works = getWorks();

  const buttons = Array.from(document.querySelectorAll('.work-button'));
  const plate = document.getElementById('plate')!;
  const thumbStrip = document.getElementById('thumbStrip')!;
  const fields = {
    counter: document.getElementById('plateCounter')!,
    title: document.getElementById('plateTitle')!,
    series: document.getElementById('plateSeries')!,
    caption: document.getElementById('plateCaption')!,
    year: document.getElementById('plateYear')!,
    ratio: document.getElementById('plateRatio')!,
    print: document.getElementById('platePrint')!,
    count: document.getElementById('plateCount')!,
  };

  let currentSeries = 0;
  let currentPhoto = 0;

  // Event delegation: clicks on any .thumb bubble up to thumbStrip
  thumbStrip.addEventListener('click', (e) => {
    const thumb = (e.target as HTMLElement).closest('.thumb');
    if (!thumb) return;
    const index = Number((thumb as HTMLElement).dataset.photoIndex);
    if (!isNaN(index)) {
      currentPhoto = index;
      const work = works[currentSeries];
      updatePlate(work);
      thumbStrip.querySelectorAll('.thumb').forEach((t, i) => {
        t.setAttribute('aria-pressed', String(i === index));
      });
    }
  });

  function renderThumbs(work: typeof works[0]) {
    thumbStrip.innerHTML = work.photos.map((photo, pi) =>
      `<button class="thumb" type="button" data-photo-index="${pi}" aria-pressed="${pi === currentPhoto}" style="background-image: url(${photo})"><span class="sr-only">Photo ${pi + 1}</span></button>`
    ).join('');
  }

  function updatePlate(work: typeof works[0]) {
    const photo = work.photos[currentPhoto];
    plate.style.setProperty('background', `url(${photo}) center / cover no-repeat`);
    fields.counter.textContent = `${String(currentPhoto + 1).padStart(2, '0')} / ${String(work.photos.length).padStart(2, '0')}`;
    fields.title.textContent = work.title;
    fields.series.textContent = work.series;
    fields.caption.textContent = work.caption;
    fields.year.textContent = work.year;
    fields.ratio.textContent = work.ratio;
    fields.print.textContent = work.print;
    fields.count.textContent = String(work.photos.length);
  }

  function selectSeries(index: number) {
    currentSeries = index;
    currentPhoto = 0;
    const work = works[index];

    buttons.forEach((btn, i) => {
      btn.setAttribute('aria-pressed', String(i === index));
    });

    updatePlate(work);
    renderThumbs(work);
    history.replaceState(null, '', `#${index}`);
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      selectSeries(Number((btn as HTMLElement).dataset.index));
    });
  });

  // Keyboard: ← → switch series, ↑ ↓ switch photos within series
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight') {
      e.preventDefault();
      if (e.shiftKey) {
        selectSeries((currentSeries + 1) % works.length);
      } else {
        currentPhoto = (currentPhoto + 1) % works[currentSeries].photos.length;
        updatePlate(works[currentSeries]);
        thumbStrip.querySelectorAll('.thumb').forEach((t, i) => {
          t.setAttribute('aria-pressed', String(i === currentPhoto));
        });
      }
    } else if (e.key === 'ArrowLeft') {
      e.preventDefault();
      if (e.shiftKey) {
        selectSeries((currentSeries - 1 + works.length) % works.length);
      } else {
        currentPhoto = (currentPhoto - 1 + works[currentSeries].photos.length) % works[currentSeries].photos.length;
        updatePlate(works[currentSeries]);
        thumbStrip.querySelectorAll('.thumb').forEach((t, i) => {
          t.setAttribute('aria-pressed', String(i === currentPhoto));
        });
      }
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      selectSeries((currentSeries + 1) % works.length);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      selectSeries((currentSeries - 1 + works.length) % works.length);
    }
  });

  // Deep link
  const hashIndex = parseInt(location.hash.slice(1), 10);
  if (hashIndex >= 0 && hashIndex < works.length) {
    selectSeries(hashIndex);
  }
</script>

<style>
  .topnav-fixed {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 20;
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom: none;
    box-shadow: none;
  }

  .topnav-fixed-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    min-height: 68px;
    padding-inline: var(--gutter);
  }

  .topnav-fixed nav {
    display: flex;
    width: 100%;
    justify-content: space-between;
    align-items: center;
  }

  .nav-home {
    position: fixed;
    left: calc(60% - 1.9rem);
    top: 0;
    height: 68px;
    display: inline-flex;
    align-items: center;
    z-index: 21;
    transform: translateX(-100%);
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
  }

  .nav-work {
    position: fixed;
    left: 60%;
    top: 0;
    height: 68px;
    display: inline-flex;
    align-items: center;
    transform: translateX(-50%);
    z-index: 21;
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--fg);
    text-decoration: none;
  }

  .nav-home:hover { color: var(--fg); }

  .hero-section {
    padding-top: calc(68px + clamp(60px, 8vw, 120px));
  }

  .hero {
    display: grid;
    grid-template-columns: 0.78fr 1.22fr;
    gap: var(--gap-2xl);
    align-items: end;
    min-height: 52svh;
  }

  h1 {
    font-size: clamp(68px, 11vw, 180px);
    line-height: 0.82;
    letter-spacing: -0.09em;
    font-weight: 800;
    text-transform: uppercase;
    max-width: 5ch;
  }

  .lead {
    font-size: var(--fs-lead);
    line-height: 1.25;
    letter-spacing: -0.04em;
    max-width: 24ch;
  }

  .viewer {
    display: grid;
    grid-template-columns: minmax(230px, 0.78fr) minmax(0, 1.7fr) minmax(180px, 0.55fr);
    gap: var(--gap-lg);
    align-items: start;
    min-height: calc(100svh - 68px);
  }

  .work-list {
    border-top: 1px solid var(--fg);
    align-self: start;
  }

  .work-button {
    width: 100%;
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: var(--gap-md);
    text-align: left;
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--border);
    color: var(--muted);
    padding: 17px 0;
    cursor: pointer;
  }

  .work-button[aria-pressed='true'],
  .work-button:hover {
    color: var(--fg);
    background: var(--fg-soft);
  }

  .work-button span:first-child {
    font-family: var(--font-mono);
  }

  .gallery-wrap {
    display: grid;
    gap: var(--gap-md);
    align-content: start;
  }

  .viewer-top,
  .viewer-bottom {
    display: flex;
    justify-content: space-between;
    gap: var(--gap-md);
    color: var(--muted);
  }

  .plate {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
    display: grid;
    place-items: center;
    min-height: 52svh;
    color: color-mix(in oklch, var(--fg) 46%, var(--surface));
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: background 0.28s ease;
  }

  .plate::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, transparent, color-mix(in oklch, var(--fg) 8%, transparent), transparent),
      repeating-linear-gradient(0deg, color-mix(in oklch, var(--fg) 8%, transparent) 0 1px, transparent 1px 10px);
    mix-blend-mode: screen;
    opacity: 0.34;
    pointer-events: none;
  }

  .plate.is-photo::before {
    opacity: 0.12;
    mix-blend-mode: multiply;
  }

  .plate span {
    position: relative;
    z-index: 1;
  }

  /* ── Thumbnail strip ── */
  .thumb-strip {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding-bottom: 4px;
  }

  .thumb {
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    border: 1px solid var(--border);
    background-size: cover;
    background-position: center;
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 0.15s ease, border-color 0.15s ease;
    padding: 0;
  }

  .thumb:hover {
    opacity: 0.8;
  }

  .thumb[aria-pressed='true'] {
    opacity: 1;
    border-color: var(--fg);
  }

  .data-panel {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--gap-xl);
    color: var(--muted);
  }

  .data-list { display: grid; gap: 14px; }

  .data-row {
    display: grid;
    grid-template-columns: 82px 1fr;
    gap: var(--gap-md);
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }

  .data-row span:last-child { color: var(--fg); }

  @media (max-width: 1080px) {
    .hero,
    .viewer {
      grid-template-columns: 1fr;
    }
    .viewer { min-height: 0; }
    .plate { min-height: 48svh; }
  }

  @media (max-width: 980px) {
    .nav-home,
    .nav-work {
      position: static;
      transform: none;
      height: auto;
    }
    .topnav-fixed nav { flex-wrap: wrap; }
  }

  @media (max-width: 620px) {
    :root { --gutter: 20px; }
    h1 { font-size: clamp(66px, 22vw, 104px); }
    .plate { min-height: 340px; }
  }
</style>
